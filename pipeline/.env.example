# Portal pipeline environment variables — copy to pipeline/.env and fill in.
# setx-persisted User env vars take precedence over these values.
# This file (.env) is gitignored; keep credentials here only.

# Healthchecks.io ping URL — REQUIRED to run ``run_automation.py``.
# Without it the orchestrator fails fast: a silent no-op would mean a dead
# check on healthchecks.io never fires on failure. See docs/RUNBOOK.md §8.
PORTAL_HEALTHCHECK_URL=https://hc-ping.com/your-check-uuid

# Gmail SMTP for sync reports (docs/automation-setup.md §7)
PORTAL_SMTP_USER=your-gmail@gmail.com
PORTAL_SMTP_PASSWORD=16-character-app-password
# PORTAL_EMAIL_TO=  # defaults to PORTAL_SMTP_USER if omitted
# PORTAL_SMTP_HOST=smtp.gmail.com
# PORTAL_SMTP_PORT=587
# PORTAL_EMAIL_FROM=  # defaults to PORTAL_SMTP_USER

# FRED API key (economic indicators, optional — skipped silently if unset)
FRED_API_KEY=your-32-char-fred-key

# Overrides (rarely needed)
# PORTAL_DOWNLOADS=C:\Users\guoyu\Downloads
# PORTAL_DB_PATH=pipeline/data/timemachine.db
